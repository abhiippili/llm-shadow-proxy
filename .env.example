# App
ENV=development
LOG_LEVEL=INFO

# Service URLs (docker-compose service names locally, App Platform URLs in prod)
PRIMARY_LLM_URL=http://primary-llm:8001
CANDIDATE_LLM_URL=http://candidate-llm:8002
JUDGE_URL=http://judge:8003

# MongoDB
MONGODB_URL=mongodb://docai:docai_password@localhost:27017/shadowproxy
MONGODB_DB_NAME=shadowproxy

# Redis
REDIS_URL=redis://localhost:6379

# Candidate mock config
RESPONSE_DELAY_SECONDS=0
DIVERGENCE_RATE=0.3

# Request timeout (seconds)
PRIMARY_TIMEOUT=10
CANDIDATE_TIMEOUT=30
JUDGE_TIMEOUT=10

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
